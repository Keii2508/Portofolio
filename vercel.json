{
  "version": 2,
  "buildCommand": "",
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}